# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= # Clerk Dashboard -> Configure -> API keys -> Publishable key
CLERK_SECRET_KEY= # Clerk Dashboard -> Configure -> API keys -> Secret key
CLERK_WEBHOOK_SECRET= # Clerk Dashboard -> Configure -> Webhooks -> select endpoint -> Signing secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in # Clerk redirect path used by the app
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up # Clerk redirect path used by the app
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard # Clerk post-login redirect path
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard # Clerk post-signup redirect path
NEXT_PUBLIC_APP_URL=https://nurturely-nu.vercel.app # Vercel project domain used for Stripe redirects and webhook dashboard setup

# Supabase / Prisma
DATABASE_URL= # Supabase Project -> Connect -> Transaction pooler URL; append ?pgbouncer=true&connection_limit=1 for Prisma
DIRECT_URL= # Supabase Project -> Connect -> Direct connection URL for Prisma migrations/schema pushes

# OpenAI
OPENAI_API_KEY= # OpenAI Platform -> API keys -> Create new secret key

# Stripe
STRIPE_SECRET_KEY= # Stripe Dashboard -> Developers -> API keys -> Secret key
STRIPE_WEBHOOK_SECRET= # Stripe Dashboard -> Developers -> Webhooks -> endpoint signing secret
NEXT_PUBLIC_STRIPE_PRICE_ID= # Stripe Dashboard -> Product catalog -> Peace Mode price id
NEXT_PUBLIC_STRIPE_PRICE_ID_FAMILY= # Stripe Dashboard -> Product catalog -> Family Mode price id

# Resend
RESEND_API_KEY= # Resend Dashboard -> API Keys -> Create API key
RESEND_FROM_EMAIL= # Resend Dashboard -> Domains -> verified sender address, e.g. Nurturely <daily@yourdomain.com>

# Vercel Cron
CRON_SECRET= # Create a long random secret in Vercel Project -> Settings -> Environment Variables; optional but recommended for protecting cron endpoints
